{
	"name": "balkon-dielen-planer",
	"version": "1.0.0",
	"private": true,
	"description": "Web-Planer für Balkon-Holzdielen: Polygon-Umriss zeichnen, automatische Dielenverlegung, Zuschnitt-Optimierung mit minimalem Verschnitt.",
	"author": "Johann Vieselthaler",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:run": "vitest run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@playwright/test": "^1.47.0",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "4.2.4",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.0",
		"globals": "17.5.0",
		"konva": "^10.0.0",
		"prettier": "^3.3.0",
		"prettier-plugin-svelte": "^3.2.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-eslint-parser": "^0.41.0",
		"tailwindcss": "4.2.4",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vitest": "^2.0.0"
	}
}
